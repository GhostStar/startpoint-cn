# ═══════════════════════════════════════════════════════════════════════
# 通用配置（两种部署方式共用）
# ═══════════════════════════════════════════════════════════════════════

# CDN 资源目录，相对于项目根目录
CDN_DIR=".cdn"

# 每日/每周复位时间（服务端时间的小时，0-23）
DAILY_RESET_HOUR=5

# CN CDN 资源版本号，必须和客户端 resourceVersion 一致
CN_RES_VERSION="1.4.54"

# 战斗掉落倍数：正常为 1；测试时可调高（如 10）加速掉落
DROP_MULTIPLIER=1

# 单人战斗是否不消耗体力：0=正常消耗；1=不检查也不扣除体力
DISABLE_STAMINA_COST=0

# 领主币商店是否取消兑换库存限制：0=按原始库存限购；1=不限量兑换
UNLIMITED_BOSS_COIN_SHOP=0

# ═══════════════════════════════════════════════════════════════════════
# 局域网部署（开发 / 测试）— 默认激活
# ═══════════════════════════════════════════════════════════════════════
# cp .env.example .env 后无需修改即可在本机启动。
# 如果客户端在另一台设备上，请将 CN_LISTEN_HOST 和 CDN_BASE_URL 设为本机
# 的实际 LAN IP（不要用 127.0.0.1）。

# CN 服务端 HTTP 监听地址与端口
CN_LISTEN_HOST="0.0.0.0"            # 监听所有网卡，允许局域网设备连接
CN_LISTEN_PORT="8001"               # HTTP API + Web 管理面板 + CDN 资源

# 全局服（国际服 Kakao 版本，一般不使用）
LISTEN_HOST="localhost"             # 全局服 HTTP 监听地址
LISTEN_PORT="8000"                  # 全局服 HTTP 端口

# CDN 客户端下载 URL
# 同机测试用 127.0.0.1；局域网其他设备用你的 LAN IP
CDN_BASE_URL="http://127.0.0.1:8001/patch/cn"

# ═══════════════════════════════════════════════════════════════════════
# 公网部署（云服务器）— 部署时取消下面注释，并填入实际值
# ═══════════════════════════════════════════════════════════════════════
# 详细步骤见 docs/deployment.md（nginx 反向代理 + 防火墙 + SSL）

# CN_LISTEN_HOST="127.0.0.1"                        # 仅监听本地，由 nginx 作为公网入口
# CDN_BASE_URL="https://<YOUR_DOMAIN>/patch/cn"     # 公网域名 + HTTPS
# SESSION_PUBLIC_HOST="<YOUR_DOMAIN>"               # 联机 TCP 房间的公网显示地址
# CN_PUBLIC_HOST="<YOUR_DOMAIN>"                    # 联机 TCP 房间的公网显示地址（回退）
# 联机 TCP 需要公网监听，SESSION_HOST="0.0.0.0" 已在下方的联机区块设置

# ═══════════════════════════════════════════════════════════════════════
# 联机 TCP 会话服务器（cooperation_room + cooperation_battle）
# ═══════════════════════════════════════════════════════════════════════

SESSION_PORT="8003"                 # TCP 监听端口
SESSION_HOST="0.0.0.0"              # 联机 TCP 需要监听公网；公网部署通过 nginx stream TLS 代理

# 联机房间自动清理（单位：毫秒）
# MULTI_ROOM_INCOMPLETE_EXPIRY_MS=900000     # 未满 3 人房间过期时间（默认 15 分钟）
# MULTI_ROOM_FULL_EXPIRY_MS=1800000          # 满 3 人房间过期时间（默认 30 分钟）
# MULTI_ROOM_CLEAN_INTERVAL_MS=60000         # 过期检查间隔（默认 60 秒）

# 联机 NPC 延迟（单位：毫秒）
# NPC_JOIN_DELAY_MS=2000                     # NPC 加入房间延迟（默认 2 秒）
# NPC_READY_DELAY_MS=500                     # NPC 准备延迟（默认 0.5 秒）
